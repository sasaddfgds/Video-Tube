# Игнорируем загруженные медиафайлы (они слишком тяжелые для GitHub)
uploads/videos/*
uploads/posters/*
uploads/avatars/*

# Но оставляем саму структуру папок, чтобы проект не ломался при запуске
!uploads/videos/.gitkeep
!uploads/posters/.gitkeep
!uploads/avatars/.gitkeep

# Игнорируем базу данных (её лучше переносить отдельно, чтобы не затереть на GitHub)
database.sqlite

# Игнорируем временные файлы Python (если использовал скрипт генерации видео)
__pycache__/
*.py[cod]

# Игнорируем логи ошибок PHP
error_log
php_errors.log

# Системные файлы
.DS_Store
Thumbs.db
